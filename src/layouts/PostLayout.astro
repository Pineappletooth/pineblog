---
import BaseLayout from './BaseLayout.astro';
const { data } = Astro.props;
const dateStr = data.pubDate ? new Date(data.pubDate).toISOString().slice(0, 10) : '';
---

<style>
  .back-link {
    color: var(--link);
    font-size: 0.8rem;
    display: inline-block;
    margin-bottom: 1.2rem;
    margin-right: 1.2rem;
  }

  .post-meta {
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .post-tags {
    display: block;
    list-style: none;
    padding: 0;
  }

  .post-tags li {
    display: inline;
  }

  .post-tags a {
    color: var(--pink);
    text-decoration: none;
    font-size: 0.8rem;
  }

  .post-tags a:hover {
    color: var(--accent);
  }
  
</style>

<BaseLayout pageTitle={data.title}>
  <div>
    <a href="/blog/" class="back-link">&lt;&lt; back to blog</a>
    <a href="/tags/" class="back-link">All tags</a>
  </div>
  <h1>{data.title}</h1>
  <div class="post-meta">
    <span>{dateStr}</span>
    <div>
      <ul class="post-tags">
        Tags: 

        {data.tags.map((tag: string) => (
          <li><a href={`/tags/${tag}`}>[{tag}]</a></li>
        ))}
      </ul>
    </div>
    
  </div>
  <div class="prose">
    <slot />
  </div>
</BaseLayout>
